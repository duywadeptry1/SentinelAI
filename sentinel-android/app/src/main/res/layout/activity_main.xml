<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#F8F9FA">

    <!-- Trạng thái khiên bảo vệ -->
    <TextView
        android:id="@+id/tvStatusTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TRẠNG THÁI HỆ THỐNG"
        android:textStyle="bold"
        android:textSize="20sp"
        android:textColor="#333333"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CHƯA KÍCH HOẠT"
        android:textStyle="bold"
        android:textSize="28sp"
        android:textColor="#D32F2F"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="40dp"/>

    <!-- Nút xin quyền Vẽ đè màn hình -->
    <Button
        android:id="@+id/btnOverlayPermission"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="#1976D2"
        android:text="1. Cấp quyền Hiển thị Cảnh báo"
        android:textColor="#FFFFFF" />

    <!-- Nút xin quyền Trợ năng (Đọc màn hình) -->
    <Button
        android:id="@+id/btnAccessibilityPermission"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="16dp"
        android:text="2. Kích hoạt Lõi Phân tích (Accessibility)"
        android:backgroundTint="#388E3C"
        android:textColor="#FFFFFF"/>

    <!-- Nút hỗ trợ Oppo/Realme -->
    <Button
        android:id="@+id/btnAutoStart"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="3. Cài đặt Tự khởi chạy (Oppo/Realme)"
        android:backgroundTint="#607D8B"
        android:textColor="#FFFFFF"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="*Sentinel AI yêu cầu 2 quyền trên để có thể quét liên kết và hiển thị cảnh báo chặn lừa đảo theo thời gian thực."
        android:textSize="12sp"
        android:textColor="#757575"
        android:textAlignment="center"
        android:layout_marginTop="24dp"/>

</LinearLayout>